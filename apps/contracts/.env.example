# =============================================================================
# apps/contracts — copy to `.env.local` and fill the deployer wallet.
# Required by `bun run publish` and `bun run upgrade`.
# =============================================================================

# Bech32 secret key for the deployer keypair (suiprivkey1...).
# This wallet pays publish/upgrade gas and receives the resulting UpgradeCap.
#
# Generate via: `sui keytool export --key-identity $(sui client active-address)`
# Keep this in .env.local (gitignored), never .env.example.
SUI_DEPLOYER_PRIVATE_KEY=

SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Note: publish/upgrade scripts write deployed.json on success — that file
# is the source of truth for the live packageId. No need to mirror it here.
