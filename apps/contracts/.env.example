# =============================================================================
# Contracts deployer — copy to `.env.local` and fill the deployer wallet.
# =============================================================================

# -- Deployer wallet ----------------------------------------------------------
# For local dev, leave both blank and the publish script falls back to whatever
# address the Sui CLI has active (`sui client active-address`).
#
# For CI / scripted deploys: SUI_DEPLOYER_PRIVATE_KEY is a bech32-encoded
# Ed25519 private key (output of `sui keytool export --key-identity <alias>`).
# Something like: `suiprivkey1q...`.
SUI_DEPLOYER_PRIVATE_KEY=

# -- Network ------------------------------------------------------------------
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# -- Post-publish state (mirrored from deployed.json) -------------------------
# Scripts write both this file and `deployed.json` on publish/upgrade.
# Do NOT edit these by hand — the scripts are the source of truth.
PACKAGE_ID=
ORIGINAL_PACKAGE_ID=
UPGRADE_CAP_ID=
