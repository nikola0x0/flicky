# =============================================================================
# apps/web — Vite env. Copy to .env.local to override defaults baked into
# src/lib/config.ts. The contracts `upgrade` script mirrors the packageId
# here automatically; everything else is optional.
# =============================================================================

# Flicky package on testnet (auto-updated by `bun --filter @flicky/contracts upgrade`).
VITE_FLICKY_PACKAGE_ID_TESTNET=

# DeepBook Predict — only override if testing against a forked or upgraded
# DeepBook deployment.
VITE_DEEPBOOK_PREDICT_PACKAGE_ID=
VITE_DEEPBOOK_PREDICT_OBJECT_ID=
VITE_DEEPBOOK_BTC_ORACLE_ID=
