# =============================================================================
# apps/web — Vite env. Copy to .env.local to override defaults baked into
# src/lib/config.ts.
#
# All values below are pre-filled with the current testnet deployment so
# `bun dev` works out of the box. Only set these if you want to point the
# UI at a different package / oracle.
# =============================================================================

# Flicky package on testnet — auto-updated by
# `bun --filter @flicky/contracts upgrade`. Source of truth is
# `apps/contracts/deployed.json`.
VITE_FLICKY_PACKAGE_ID_TESTNET=0x505cdc9868df09c5a3cbfa469971feb795a17ecd2fec35405dd951e10d624f26

# DeepBook Predict on testnet. Override only when testing against a
# forked or upgraded DeepBook deployment.
VITE_DEEPBOOK_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
VITE_DEEPBOOK_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a

# Fallback BTC OracleSVI id — used only when the registry event query
# fails. Runtime auto-resolves the freshest active one via
# `findLatestOracleSvi()`.
VITE_DEEPBOOK_BTC_ORACLE_ID=0xdc8ae118f2770366e0f0a91deb5dd8533150cb79b343f83e800a9a951aca6cba

# Backend URL for sponsored-gas + Deckmaster. Defaults to local dev
# server.
VITE_SPONSOR_URL=http://localhost:3001
VITE_DECKMASTER_URL=http://localhost:3001

# Sui network (testnet | mainnet) — read by lib/sponsor.ts when calling
# the sponsor endpoint.
VITE_SUI_NETWORK=testnet

# ── Enoki zkLogin (optional) ──────────────────────────────────────────
# Without these, only browser-extension wallets show in the connect
# modal. With them, dapp-kit's useWallets() also surfaces a
# "Sign in with Google" entry that uses Enoki-issued zkLogin
# credentials (no extension required).
#
# Get from https://portal.enoki.mystenlabs.com — same key works for
# testnet + mainnet.
VITE_ENOKI_API_KEY=

# OAuth client ids. Each provider requires you to register the app's
# URL (e.g. http://localhost:5173) as an allowed redirect.
#   Google:   https://console.cloud.google.com/apis/credentials
#   Facebook: https://developers.facebook.com/apps
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_CLIENT_ID=
