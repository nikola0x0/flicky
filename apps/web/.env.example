# =============================================================================
# apps/web — Vite env. Copy to .env.local to override defaults baked into
# src/lib/config.ts.
#
# All values below are pre-filled with the current testnet deployment so
# `bun dev` works out of the box. Only set these if you want to point the
# UI at a different package / oracle.
# =============================================================================

# Flicky package on testnet — auto-updated by
# `bun --filter @flicky/contracts upgrade`. Source of truth is
# `apps/contracts/deployed.json`.
VITE_FLICKY_PACKAGE_ID_TESTNET=0x6c6be7201465b165c82e717b75074060208495118dbda5afb19471be89d3cbfb

# DeepBook Predict 6-24 on testnet — package + shared objects + BTC oracle
# feeds. Override only when testing against a forked/upgraded deployment.
# (4-16's single `Predict` object + `OracleSVI` no longer exist in 6-24;
# markets are discovered from the predict indexer instead.)
VITE_DEEPBOOK_PREDICT_PACKAGE_ID=0xdb3ef5a5129920e59c9b2ae25a77eddb48acd0e1c6307b97073f0e076016446e
VITE_DEEPBOOK_PROTOCOL_CONFIG_ID=0x2325224629b4bd96d1f1d7ee937e07f8a06f861018a130bbb26db09cb0394cb6
VITE_DEEPBOOK_POOL_VAULT_ID=0xfde98c636eb8a7aba59c3a238cfee6b576b7118d1e5ffa2952876c4b270a3a2a
VITE_DEEPBOOK_PREDICT_REGISTRY_ID=0x54afbf245caf42466cedb5756ed7816f34f544afdfa13579a862eccf3afa21ca
VITE_DEEPBOOK_ACCOUNT_PACKAGE_ID=0xb9389eac8d59170ffd1427c1a66e5c8306263464fcc6615e825c1f5b3e15da3b
VITE_DEEPBOOK_ACCOUNT_REGISTRY_ID=0x3c54d5b8b6bca376fc289121838ad02f8a5b3843242b9ad7e8f8245720e685a2
VITE_DEEPBOOK_ORACLE_REGISTRY_ID=0xf3deaff68cbd081a35ec21653af6f671d2ad5f012f3b4d817d81752843374136
VITE_DEEPBOOK_PYTH_FEED_ID=0xc78d7de16217d46d21b92ae475da799448be30b71a758dc6d7bb3ac2f1c35afb
VITE_DEEPBOOK_BS_SPOT_FEED_ID=0xcdc5fa7364e60fd2504aa96f65b707dc0734e507a919b1a7d7d63164fd67b745
VITE_DEEPBOOK_BS_FORWARD_FEED_ID=0xe72c734ea8d8dcbc9183d9d8f96f51aaa1fb5034d5ed33ac60d67d261e15b48a
VITE_DEEPBOOK_BS_SVI_FEED_ID=0xdc2f8270676bd05fb28491e8d4a41a495722fda7a454926dd66dbba256a21c69
VITE_DEEPBOOK_ACCUMULATOR_ROOT_ID=0xacc
VITE_DEEPBOOK_PREDICT_INDEXER_URL=https://predict-server-beta.testnet.mystenlabs.com

# Backend URL for sponsored-gas + Deckmaster. Defaults to local dev
# server.
VITE_SPONSOR_URL=http://localhost:3001
VITE_DECKMASTER_URL=http://localhost:3001

# Sui network (testnet | mainnet) — read by lib/sponsor.ts when calling
# the sponsor endpoint.
VITE_SUI_NETWORK=testnet

# ── Enoki zkLogin (optional) ──────────────────────────────────────────
# Without these, only browser-extension wallets show in the connect
# modal. With them, dapp-kit's useWallets() also surfaces a
# "Sign in with Google" entry that uses Enoki-issued zkLogin
# credentials (no extension required).
#
# Get from https://portal.enoki.mystenlabs.com — same key works for
# testnet + mainnet.
VITE_ENOKI_API_KEY=

# OAuth client ids. Each provider requires you to register the app's
# URL (e.g. http://localhost:5173) as an allowed redirect.
#   Google:   https://console.cloud.google.com/apis/credentials
#   Facebook: https://developers.facebook.com/apps
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_CLIENT_ID=
