# apps/web — production build env (loaded by `vite build`). All values are
# client-public (Vite inlines VITE_* into the bundle): public Enoki key,
# OAuth client id, on-chain package/oracle ids, and the Railway backend URL.
# No secrets here. Override per-deploy with Railway build variables if needed.

# Flicky backend (apps/server) on Railway — sponsored gas + Deckmaster + WS.
VITE_SERVER_HTTP_URL=https://flicky-server-production.up.railway.app
VITE_SERVER_WS_URL=wss://flicky-server-production.up.railway.app/ws
VITE_SPONSOR_URL=https://flicky-server-production.up.railway.app
VITE_DECKMASTER_URL=https://flicky-server-production.up.railway.app

# Sui network.
VITE_SUI_NETWORK=testnet

# Flicky package (testnet) — matches apps/contracts/deployed.json.
VITE_FLICKY_PACKAGE_ID_TESTNET=0x6c6be7201465b165c82e717b75074060208495118dbda5afb19471be89d3cbfb

# DeepBook Predict 6-24 (testnet). Package + shared objects + BTC oracle feeds.
