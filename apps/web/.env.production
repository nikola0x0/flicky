# apps/web — production build env (loaded by `vite build`). All values are
# client-public (Vite inlines VITE_* into the bundle): public Enoki key,
# OAuth client id, on-chain package/oracle ids, and the Railway backend URL.
# No secrets here. Override per-deploy with Railway build variables if needed.

# Flicky backend (apps/server) on Railway — sponsored gas + Deckmaster + WS.
VITE_SERVER_HTTP_URL=https://flicky-server-production.up.railway.app
VITE_SERVER_WS_URL=wss://flicky-server-production.up.railway.app/ws
VITE_SPONSOR_URL=https://flicky-server-production.up.railway.app
VITE_DECKMASTER_URL=https://flicky-server-production.up.railway.app

# Sui network.
VITE_SUI_NETWORK=testnet

# Flicky package (testnet) — matches apps/contracts/deployed.json.
VITE_FLICKY_PACKAGE_ID_TESTNET=0xe1b1853ab66c44dbe00a4b64238a3f64e226dfcd50c331d095fb38599bdc1854

# DeepBook Predict (testnet).
VITE_DEEPBOOK_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
VITE_DEEPBOOK_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
VITE_DEEPBOOK_BTC_ORACLE_ID=0xdc8ae118f2770366e0f0a91deb5dd8533150cb79b343f83e800a9a951aca6cba

# dUSDC + SUI coin types.
VITE_DUSDC_COIN_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
VITE_SUI_COIN_TYPE=0x2::sui::SUI

# SUI ↔ dUSDC AMM swap (testnet deployment).
VITE_SWAP_PACKAGE_ID=0x51ea0f29321f3c25f8b2f530ecd3ed3dec569d954c8832d318de7e203653a936
VITE_SWAP_POOL_ID=0x778c0b0570a541ec38463a9e2f1596e25777570a466da0ba1796bdbe2846bdcd

# Enoki zkLogin — PUBLIC key (safe in client bundle).
VITE_ENOKI_API_KEY=enoki_public_8170d7cff8a4c5bce48ecf73bf97f135
# Google OAuth client id (public). Add the Railway web origin to the allowed
# JavaScript origins + redirect URIs in the Google console.
VITE_GOOGLE_CLIENT_ID=1015826420777-n3r8v2che355oiucuvocpmph6vmhgeb4.apps.googleusercontent.com
