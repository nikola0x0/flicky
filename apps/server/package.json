{
  "name": "server",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts & bun --watch src/scripts/keeper.ts & wait",
    "dev:serveronly": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test src/lib",
    "test:e2e": "bun test src/scripts/e2e.test.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "deepbook:discover": "bun run src/scripts/deepbook-discover.ts",
    "demo:duel": "bun run src/scripts/demo-duel.ts",
    "bot": "bun run src/scripts/bot.ts",
    "keeper": "bun run src/scripts/keeper.ts"
  },
  "dependencies": {
    "@mysten/enoki": "^1.0.8",
    "@mysten/sui": "^1.30"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.3.0",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
