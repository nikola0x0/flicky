# =============================================================================
# apps/server — copy to .env.local for local dev.
# =============================================================================

# ── Server ─────────────────────────────────────────────────────────────
PORT=3001

# Network the SuiClient connects to (testnet | mainnet | devnet | localnet).
SUI_NETWORK=testnet

# Optional: override the fullnode URL. Defaults to the public node for SUI_NETWORK.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Optional: override the flicky package id baked into the sponsor allowlist
# + keeper PTBs per network. Defaults to apps/contracts/deployed.json
# (testnet). Set FLICKY_PACKAGE_MAINNET when deploying to mainnet.
FLICKY_PACKAGE_ID=
FLICKY_PACKAGE_TESTNET=
FLICKY_PACKAGE_MAINNET=

# ── Signers (suiprivkey1… bech32) ──────────────────────────────────────

# Bech32 secret key for the admin keypair. Used only by the standalone
# scripts that sign transactions (demo:duel, e2e tests).
#
# Generate via: `sui keytool export --key-identity $(sui client active-address)`
ADMIN_SECRET_KEY=

# Bech32 secret key for the settled-redeem keeper. Required when
# KEEPER_ENABLED is true (the default). Falls back to BOT_SECRET_KEY if
# unset. Any funded testnet wallet works — keeper functions are
# permissionless on chain.
KEEPER_SECRET_KEY=
BOT_SECRET_KEY=

# Optional: disable the in-process keeper (e.g. for staging where you
# only want HTTP/WS). Default: keeper is enabled if a key is present.
KEEPER_ENABLED=
KEEPER_POLL_INTERVAL_MS=

# ── Sponsored gas (address-balance sponsor) ────────────────────────────

# Required to enable POST /sponsor. A bech32 suiprivkey1… key whose ADDRESS
# BALANCE holds SUI — the sponsor pays gas from that balance (empty gas
# payment), NOT from gas coins. Generate a key, then fund its address balance
# once with `bun run fund:sponsor` (the faucet gives coin objects, not address
# balance, so the deposit step is required). Without this, /sponsor returns 503
# and the web client falls back to wallet-paid signAndExecute.
SPONSOR_SECRET_KEY=

# Optional: max gas (MIST) the sponsor will cover per transaction, enforced by
# the gasBudget validator. Defaults to 100000000 (0.1 SUI).
SPONSOR_MAX_GAS_BUDGET=

# Optional: separate funder key for `fund:sponsor`. Defaults to
# SPONSOR_SECRET_KEY (self-fund from the sponsor's own faucet coins).
FUND_FROM_SECRET_KEY=

# Optional: comma-separated origins allowed to call /sponsor. Leave UNSET
# (or "*") for any-origin dev. Set for production
# (e.g. "https://flicky.app,http://localhost:5173").
ALLOWED_ORIGIN=

# ── Deckmaster ─────────────────────────────────────────────────────────

# Minimum headroom each card's oracle must clear at duel creation. PRD
# says the 5 cards are the nearest oracle resolutions strictly >10 min
# out — adjust here if you want a wider window for demos.
DECK_CARD_MIN_HEADROOM_MS=600000

# ── Database (Postgres via Bun.sql) ────────────────────────────────────

# All persistence — indexer cursors, the duel mirror, chat, player
# ratings, and the deckmaster commit-reveal plaintext store — lives in
# Postgres. REQUIRED for DB-backed features (a missing URL fails fast at
# the first query).
#
#   - On Railway the deployed service references the Postgres plugin's
#     private URL:  DATABASE_URL=${{Postgres.DATABASE_URL}}
#   - Locally, point at the public proxy URL (…proxy.rlwy.net:PORT) or a
#     local Postgres, e.g. a throwaway docker container.
DATABASE_URL=

# Connection-pool ceiling for Bun.sql (default 10).
DB_POOL_MAX=

# Tests NEVER use DATABASE_URL — they require an explicit throwaway DB so
# they can't mutate a real one. Set TEST_DATABASE_URL to run DB-backed
# suites (otherwise they skip):
#   docker run -d --name flicky-test-pg -e POSTGRES_PASSWORD=test \
#     -e POSTGRES_DB=flicky_test -p 55432:5432 postgres:16-alpine
#   TEST_DATABASE_URL=postgres://postgres:test@127.0.0.1:55432/flicky_test bun test
TEST_DATABASE_URL=

# ── DeepBook Predict (testnet defaults baked in) ───────────────────────

# Used by the keeper to read PredictManagers and build the per-card
# redeem_permissionless PTBs. Mirror these in apps/web/.env.example so
# the UI and the server point at the same DeepBook deployment.
DEEPBOOK_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
DEEPBOOK_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a

# Mainnet DeepBook Predict package. Sponsor refuses mainnet sponsored
# transactions until this is set — a wrong package id would silently
# allow an attacker to drain the sponsor wallet through unrelated
# MoveCalls, so the placeholder must be explicit at deploy time.
DEEPBOOK_PREDICT_PACKAGE_MAINNET=

# SUI ↔ dUSDC AMM swap module — published separately from the flicky
# duel package. Default points at the testnet deployment from
# apps/contracts/swap/Published.toml. Set SWAP_PACKAGE_MAINNET for prod.
SWAP_PACKAGE_ID=0x51ea0f29321f3c25f8b2f530ecd3ed3dec569d954c8832d318de7e203653a936
SWAP_PACKAGE_MAINNET=

# Canonical dUSDC coin type on testnet (1e6 decimals). The keeper compares
# Duel<T>'s T against this to decide whether to redeem Predict positions
# (dUSDC stake) or skip (legacy free SUI duel).
DUSDC_COIN_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# ── Matchmaking ────────────────────────────────────────────────────────
# Sync-only PvP: queue waits indefinitely for a human opponent. Solo-vs-bot
# is handled by Practice Mode (`practice_start` WS message), not by queue
# fallback. MATCH_BOT_FILL_DELAY_MS / QUEUE_GC_INTERVAL_MS are intentionally
# absent — no code consumes them.

# Grace period after a player socket closes before the server emits
# `peer_forfeit` to the remaining room subscribers. If they reconnect +
# resubscribe within this window, peers get `peer_rejoined` instead.
PEER_FORFEIT_GRACE_MS=30000

# ── Indexer (duel event poller) ────────────────────────────────────────

INDEXER_ENABLED=
INDEXER_POLL_INTERVAL_MS=3000
