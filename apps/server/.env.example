# =============================================================================
# apps/server — copy to .env.local for local dev.
# =============================================================================

# Network the SuiClient connects to (testnet | mainnet | devnet | localnet).
SUI_NETWORK=testnet

# Optional: override the fullnode URL. Defaults to the public node for SUI_NETWORK.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Bech32 secret key for the admin/keeper keypair (suiprivkey1...).
#
# Required by:
#   - `bun run demo:duel`       (signs create + join + settle txns)
#   - `bun run test:e2e`        (signs the full live-testnet flow)
#
# NOT required by:
#   - `bun run dev`             (Bun.serve HTTP/WS, no signer)
#   - `bun run deepbook:discover` (read-only)
#   - `bun run test`            (unit tests; e2e skipped without this)
#
# Generate via: `sui keytool export --key-identity $(sui client active-address)`
# Keep this in .env.local (gitignored), never .env.example.
ADMIN_SECRET_KEY=

# Bech32 secret key for the matchmaking bot (suiprivkey1...).
# Used by `bun run bot` only — auto-joins PENDING duels and plays out the
# 5 swipes. Keep separate from ADMIN_SECRET_KEY (so the bot can't drain
# the deployer wallet) and fund with ~0.2 testnet SUI.
BOT_SECRET_KEY=

# Optional: how long the bot waits after DuelCreated before joining
# (ms). Default 5000.
BOT_JOIN_DELAY_MS=

# Optional bech32 secret key for the settled-redeem keeper. Falls back
# to BOT_SECRET_KEY if unset. Keeper functions are permissionless on
# chain, so any funded testnet wallet works — separate var exists only
# so the matchmaking and keeping concerns can run with different
# wallets in production.
KEEPER_SECRET_KEY=

# Optional: keeper poll interval in ms. Default 10000.
KEEPER_POLL_INTERVAL_MS=

# HTTP/WS port for Bun.serve.
PORT=3001

# ── Enoki sponsored gas ────────────────────────────────────────────────
# Required to enable POST /sponsor. Get from https://portal.enoki.mystenlabs.com
# (one key works for testnet + mainnet). Without it, /sponsor returns 503
# and the web client falls back to wallet-paid signAndExecute.
ENOKI_PRIVATE_KEY=

# Optional: comma-separated origins allowed to call /sponsor. Leave UNSET
# (or "*") for any-origin dev. Set for production
# (e.g. "https://flicky.app,http://localhost:5173").
ALLOWED_ORIGIN=

# Optional: override the flicky packageId baked into the sponsor allowlist
# per network. Defaults to apps/contracts/deployed.json for testnet.
FLICKY_PACKAGE_TESTNET=
FLICKY_PACKAGE_MAINNET=

# ── DeepBook Predict (testnet defaults) ──────────────────────────────────
# Used by the keeper to read PredictManagers and to build
# `predict::redeem_permissionless` PTBs after a duel settles. Mirror these
# in apps/web/.env.example so the UI and the server point at the same
# DeepBook deployment.
DEEPBOOK_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
DEEPBOOK_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a

# Canonical dUSDC coin type on testnet (1e6 decimals). The keeper compares
# Duel<T>'s T against this to decide whether to redeem Predict positions
# (dUSDC stake) or skip (free SUI duel).
DUSDC_COIN_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
