{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "globalPassThroughEnv": [
    "SUI_NETWORK",
    "SUI_RPC_URL",
    "VITE_FLICKY_PACKAGE_ID_TESTNET",
    "VITE_DEEPBOOK_PREDICT_PACKAGE_ID",
    "VITE_DEEPBOOK_PREDICT_OBJECT_ID",
    "VITE_DEEPBOOK_BTC_ORACLE_ID",
    "VITE_DECKMASTER_URL",
    "VITE_SPONSOR_URL",
    "VITE_SUI_NETWORK",
    "VITE_ENOKI_API_KEY",
    "VITE_GOOGLE_CLIENT_ID",
    "VITE_FACEBOOK_CLIENT_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "eslint.config.*"],
      "outputs": []
    },
    "format": {
      "dependsOn": ["^format"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "knip": {
      "inputs": ["$TURBO_DEFAULT$", "knip.json"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
