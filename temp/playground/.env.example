# DeepBook Predict Playground Config
# Copy this to .env.local and fill in your testnet values

# Network
VITE_NETWORK=testnet

# DeepBook Predict Package & Objects (from deployment or Sui Explorer)
VITE_PREDICT_PACKAGE_ID=
VITE_REGISTRY_ID=

# Optional: if not provided, will be derived from REGISTRY_ID
VITE_PREDICT_OBJECT_ID=

# Oracle & Price Feed (from your test market)
VITE_MARKET_ORACLE_ID=
VITE_PYTH_SOURCE_ID=

# dUSDC Package & Type
VITE_DUSDC_PACKAGE_ID=

# Optional: Custom RPC URL
# VITE_RPC_URL=https://rpc.testnet.sui.io
